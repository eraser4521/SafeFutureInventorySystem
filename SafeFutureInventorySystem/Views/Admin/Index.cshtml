@model List<SafeFutureInventorySystem.Controllers.AdminUserRow>

@{
    ViewData["Title"] = "Admin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Admin</h2>
        <a asp-action="Create" asp-controller="Admin" class="btn btn-primary">Create User</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["GeneratedPassword"] != null)
    {
        <div class="alert alert-warning">
            <strong>@TempData["GeneratedPassword"]</strong>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-bordered table-striped align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Password Status</th>
                    <th style="width: 320px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Name</td>
                        <td>@user.Email</td>
                        <td>@user.Role</td>
                        <td>
                            @if (user.MustChangePassword)
                            {
                                <span class="badge bg-warning text-dark">Must Set Password</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </td>
                        <td>
                            <!-- FORCE SINGLE ROW BUTTONS -->
                            <div style="display:flex; gap:8px; flex-wrap:nowrap; align-items:center;">
                                
                                <a asp-action="Edit" asp-controller="Admin" asp-route-id="@user.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>

                                @if (user.Role != "Admin")
                                {
                                    <form asp-action="ResetPassword" asp-controller="Admin" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning">
                                            Reset Code
                                        </button>
                                    </form>
                                }

                                @if (user.Role != "Admin")
                                {
                                    <form asp-action="Delete" asp-controller="Admin" method="post" style="margin:0;"
                                          onsubmit="return confirm('Delete this user?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </button>
                                    </form>
                                }

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>