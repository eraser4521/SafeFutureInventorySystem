@model ErrorViewModel
@{
    ViewData["Title"] = "We hit a snag";
}

<div class="alert alert-danger">
    <h1 class="h4 mb-2">@(Model.UserMessage ?? "We couldn't process your request.")</h1>
    <p class="mb-0">Please try again. If the issue persists, contact a maintainer with the details below.</p>
</div>

<div class="card">
    <div class="card-body">
        <p class="mb-1">
            <strong>Request ID:</strong> <code>@(Model.RequestId ?? "Unavailable")</code>
        </p>
        @if (Model.StatusCode.HasValue)
        {
            <p class="mb-1"><strong>Status code:</strong> @Model.StatusCode</p>
        }
        @if (!string.IsNullOrEmpty(Model.Path))
        {
            <p class="mb-1"><strong>Path:</strong> @Model.Path</p>
        }
        @if (!string.IsNullOrEmpty(Model.Detail))
        {
            <details class="mt-3">
                <summary>Technical details</summary>
                <pre class="mb-0">@Model.Detail</pre>
            </details>
        }
    </div>
</div>
