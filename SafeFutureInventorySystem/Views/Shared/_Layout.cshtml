@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Antiforgery
@using SafeFutureInventorySystem.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject IAntiforgery Antiforgery

@{
    var requestVerificationToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="request-verification-token" content="@requestVerificationToken" />
    <title>@ViewData["Title"] - SafeFutureInventorySystem</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SafeFutureInventorySystem.styles.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
</head>

<body data-no-taghelper="true">

<header class="page-header">
    <a href="@Url.Action("Index", "Home")" class="logo-container">
        <img src="~/images/safe-future-logo.png"
             alt="Safe Future Foundation"
             class="logo-image" />
        <div class="logo-text"></div>
    </a>

    <div class="header-actions">

        <a href="@Url.Action("Index", "Home")"
           class="btn btn-primary btn-header">
            <i class="fas fa-home"></i> Dashboard
        </a>

        <a href="@Url.Action("Index", "Inventory")"
           class="btn btn-info btn-header">
            <i class="fas fa-clipboard-list"></i> Inventory
        </a>

        @if (User != null && User.IsInRole("Admin"))
        {
            <div class="dropdown nav-export-dropdown">
                <button class="btn btn-success btn-header dropdown-toggle" type="button" id="navExportDropdownBtn" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-file-export"></i> Export
                </button>
                <div class="dropdown-menu" aria-labelledby="navExportDropdownBtn">
                    <a href="@Url.Action("ExportFullInventoryPdf", "Inventory")" class="dropdown-item">
                        <i class="fas fa-file-pdf text-danger"></i> Export PDF
                    </a>
                    <a href="@Url.Action("ExportInventoryCsv", "Inventory")" class="dropdown-item">
                        <i class="fas fa-file-csv text-info"></i> Export CSV
                    </a>
                    <a href="@Url.Action("ExportInventoryExcel", "Inventory")" class="dropdown-item">
                        <i class="fas fa-file-excel text-success"></i> Export Excel
                    </a>
                </div>
            </div>

            <a href="@Url.Action("Index", "Admin")"
               class="btn btn-warning btn-header">
                <i class="fas fa-user-shield"></i> Admin
            </a>
        }

        <form asp-controller="Account" asp-action="Logout" method="post" class="header-logout-form" onsubmit="return confirm('Are you sure you want to logout?');">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-header">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </form>

    </div>
</header>

<div class="container-fluid app-shell">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
