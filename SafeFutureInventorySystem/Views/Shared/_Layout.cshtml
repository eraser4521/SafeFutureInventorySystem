<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - SafeFutureInventorySystem</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/SafeFutureInventorySystem.styles.css" asp-append-version="true"/>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
</head>
<body>
    <header class="page-header">
        <div class="logo-container">
            <img src="~/images/safe-future-logo.png" alt="Safe Future Foundation" class="logo-image" />
            <div class="logo-text">Safe Future Foundation</div>
        </div>
        <div class="header-actions">
            <a href="@Url.Action("Index", "Inventory")" class="btn btn-primary btn-header">
                <i class="fas fa-home"></i> Inventory Page
            </a>
            <button class="btn btn-primary btn-header" onclick="alert('Scan feature coming soon!')">
                <i class="fas fa-barcode"></i> Scan In
            </button>
            <button class="btn btn-primary btn-header" onclick="alert('PDF export coming soon!')">
                <i class="fas fa-file-pdf"></i> Create PDF
            </button>
            <a href="@Url.Action("Index", "QRCodes")" class="btn btn-primary btn-header">
                <i class="fas fa-qrcode"></i> QR Codes
            </a>
            <button class="btn btn-primary btn-header">
                <i class="fas fa-user"></i> Account
            </button>
            <button class="btn btn-danger btn-header" onclick="if(confirm('Are you sure you want to logout?')) { alert('Logout functionality here'); }">
                <i class="fas fa-sign-out-alt"></i> Logout
            </button>
        </div>
    </header>

<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

    <!-- jQuery (must load before Bootstrap) -->
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
