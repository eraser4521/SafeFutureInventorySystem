@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Safe Future Foundation</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
  
    <main class="auth-main" role="main">
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            min-height: 100vh;
            font-family: 'Segoe UI', Arial, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(200, 169, 107, 0.10), transparent 24%),
                linear-gradient(135deg, #f7f8fb 0%, #eef2f7 100%);
            position: relative;
            overflow-x: hidden;
        }

        .auth-header {
            position: absolute;
            top: 26px;
            left: 34px;
            z-index: 30;
        }

        .auth-logo {
            height: 96px;
            width: auto;
            display: block;
            filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.18));
        }

        .auth-main {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }

        @@media (max-width: 900px) {
            .auth-main {
                padding: clamp(12px, 2.5vw, 16px);
            }
        }

        @@media (max-width: 768px) {
            .auth-header {
                top: 18px;
                left: 18px;
            }

            .auth-logo {
                height: 74px;
            }

            .auth-main {
                padding: clamp(8px, 2.2vw, 12px);
                min-height: 100dvh;
            }
        }

        @@media (max-width: 768px) and (max-height: 700px) {
            .auth-main {
                align-items: flex-start;
            }
        }
    </style>
</body>
</html>
