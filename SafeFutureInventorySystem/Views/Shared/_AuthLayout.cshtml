@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Safe Future Foundation</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="background-color:#979797; font-family:'Segoe UI', Arial, sans-serif;">
    <header style="padding:32px 48px;">
        <img src="~/images/safefuturelogo.webp"
             alt="Safe Future Foundation Logo"
             style="height:110px; filter: drop-shadow(0px 2px 4px rgba(0,0,0,0.3));" />
    </header>

    <main role="main">
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>
