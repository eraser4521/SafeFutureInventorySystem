@model SafeFutureInventorySystem.Models.InventoryItem
@{
    ViewData["Title"] = "Item Details";
}

<div class="container">
    <h2>@Model.Name</h2>

    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Quantity</dt>
        <dd class="col-sm-10">@Model.Quantity</dd>

        <dt class="col-sm-2">Date Added</dt>
        <dd class="col-sm-10">@Model.DateAdded.ToShortDateString()</dd>
    </dl>

    <div>
        <a class="btn btn-primary" href="@Url.Action("Generate", "QRCodes", new { id = Model.Id })" target="_blank">Preview QR Code</a>
        <a class="btn btn-secondary" href="@Url.Action("Edit", "Inventory", new { id = Model.Id })">Edit</a>
        <a class="btn btn-link" href="@Url.Action("Index", "Inventory")">Back to list</a>
    </div>
</div>