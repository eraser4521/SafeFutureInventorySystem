@model SafeFutureInventorySystem.Models.InventoryFilterViewModel

@{
    ViewBag.Title = "Inventory Management";
}

<div class="container-fluid">
    <h2>
        <i class="fas fa-boxes"></i> Inventory Management
    </h2>

    <!-- Search and Filter Section -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="form-inline">
                <div class="row w-100">
                    <!-- USER STORY 4: Search by Name -->
                    <div class="col-md-4 mb-3">
                        <div class="input-group w-100">
                            <div class="input-group-prepend">
                                <span class="input-group-text">
                                    <i class="fas fa-search"></i>
                                </span>
                            </div>
                            <input type="text" name="searchTerm" class="form-control"
                                   placeholder="Search by name or description..."
                                   value="@Model.SearchTerm" id="searchInput" />
                        </div>
                    </div>

                    <!-- USER STORY 2: Filter by Expiration -->
                    <div class="col-md-3 mb-3">
                        <select name="expirationFilter" class="form-control w-100">
                            <option value="">All Items</option>
                            <option value="Expired" selected="@(Model.ExpirationFilter == "Expired")">Expired</option>
                            <option value="ExpiringSoon" selected="@(Model.ExpirationFilter == "ExpiringSoon")">Expiring Soon (7 days)</option>
                            <option value="ExpiringThisMonth" selected="@(Model.ExpirationFilter == "ExpiringThisMonth")">Expiring This Month (30 days)</option>
                            <option value="Good" selected="@(Model.ExpirationFilter == "Good")">Good Condition</option>
                            <option value="NoExpiration" selected="@(Model.ExpirationFilter == "NoExpiration")">No Expiration Date</option>
                        </select>
                    </div>

                    <!-- Date Range Filter -->
                    <div class="col-md-2 mb-3">
                        <input type="date" name="fromDate" class="form-control"
                               value="@Model.FromDate?.ToString("yyyy-MM-dd")" placeholder="From Date" />
                    </div>

                    <div class="col-md-2 mb-3">
                        <input type="date" name="toDate" class="form-control"
                               value="@Model.ToDate?.ToString("yyyy-MM-dd")" placeholder="To Date" />
                    </div>

                    <div class="col-md-1 mb-3">
                        <button type="submit" class="btn btn-primary btn-block">
                            <i class="fas fa-filter"></i> Filter
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="mb-3">
        <button type="button" class="btn btn-success" onclick="location.href='@Url.Action("Create", "Inventory")'">
            <i class="fas fa-plus"></i> Add New Item
        </button>

        <!-- USER STORY 1: Remove Selected Items -->
        <button type="button" class="btn btn-danger" id="removeSelectedBtn" disabled>
            <i class="fas fa-trash"></i> Remove Selected (<span id="selectedCount">0</span>)
        </button>
    </div>

    <!-- Inventory Table -->
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="inventoryTable">
                    <thead class="thead-dark">
                        <tr>
                            <th>
                                <input type="checkbox" id="selectAll" />
                            </th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="Name"
                                   asp-route-sortOrder="@(Model.SortBy == "Name" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Name
                                    @if (Model.SortBy == "Name")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>Description</th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="Quantity"
                                   asp-route-sortOrder="@(Model.SortBy == "Quantity" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Quantity
                                    @if (Model.SortBy == "Quantity")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="DateAdded"
                                   asp-route-sortOrder="@(Model.SortBy == "DateAdded" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Date Added
                                    @if (Model.SortBy == "DateAdded")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="ExpirationDate"
                                   asp-route-sortOrder="@(Model.SortBy == "ExpirationDate" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Expiration Date
                                    @if (Model.SortBy == "ExpirationDate")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr data-item-id="@item.Id">
                                    <td>
                                        <input type="checkbox" class="item-checkbox" value="@item.Id" />
                                    </td>
                                    <td>@item.Name</td>
                                    <td>@(item.Description ?? "N/A")</td>
                                    <td>
                                        <span class="badge badge-light text-dark">@item.Quantity</span>
                                    </td>
                                    <td>
                                        @item.DateAdded.ToString("MM/dd/yyyy")
                                    </td>
                                    <td>
                                        @if (item.ExpirationDate.HasValue)
                                        {
                                            @item.ExpirationDate.Value.ToString("MM/dd/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Expiration</span>
                                        }
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = "";
                                            var statusIcon = "";
                                            switch (item.ExpirationStatus)
                                            {
                                                case "Expired":
                                                    statusClass = "badge-danger";
                                                    statusIcon = "fa-times-circle";
                                                    break;
                                                case "Expiring Soon":
                                                    statusClass = "badge-warning";
                                                    statusIcon = "fa-exclamation-triangle";
                                                    break;
                                                case "Expiring This Month":
                                                    statusClass = "badge-warning";
                                                    statusIcon = "fa-clock";
                                                    break;
                                                case "Good":
                                                    statusClass = "badge-success";
                                                    statusIcon = "fa-check-circle";
                                                    break;
                                                default:
                                                    statusClass = "badge-secondary";
                                                    statusIcon = "fa-infinity";
                                                    break;
                                            }
                                        }
                                        <span class="badge @statusClass">
                                            <i class="fas @statusIcon"></i> @item.ExpirationStatus
                                        </span>
                                    </td>
                                    <td>
                                        <!-- USER STORY 3: Adjust Quantity Button -->
                                        <button type="button" class="btn btn-sm btn-warning"
                                                onclick="openAdjustQuantityModal(@item.Id, '@item.Name', @item.Quantity)">
                                            <i class="fas fa-edit"></i> Adjust
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center">
                                    <p class="text-muted">No items found matching your criteria.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-page="@(Model.PageNumber - 1)">Previous</a>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-page="@i">@i</a>
                            </li>
                        }

                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-page="@(Model.PageNumber + 1)">Next</a>
                            </li>
                        }
                    </ul>
                </nav>
            }

            <div class="text-center text-muted">
                Showing @((Model.PageNumber - 1) * Model.PageSize + 1) to
                @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))
                of @Model.TotalCount items
            </div>
        </div>
    </div>
</div>

<!-- USER STORY 3: Adjust Quantity Modal -->
<div class="modal fade" id="adjustQuantityModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Adjust Quantity</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="adjustQuantityForm">
                    <input type="hidden" id="adjustItemId" />

                    <div class="form-group">
                        <label>Item Name:</label>
                        <input type="text" class="form-control" id="adjustItemName" readonly />
                    </div>

                    <div class="form-group">
                        <label>Current Quantity:</label>
                        <input type="number" class="form-control" id="adjustCurrentQuantity" readonly />
                    </div>

                    <div class="form-group">
                        <label for="adjustNewQuantity">New Quantity: <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="adjustNewQuantity"
                               min="0" required />
                    </div>

                    <div class="form-group">
                        <label for="adjustReason">Reason for Adjustment: <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="adjustReason" rows="3"
                                  placeholder="E.g., Physical stock check, damaged items, etc." required></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitQuantityAdjustment()">
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/js/all.min.js"></script>

    <script>
        $(document).ready(function() {
            // Select All checkbox functionality
            $('#selectAll').change(function() {
                $('.item-checkbox').prop('checked', this.checked);
                updateSelectedCount();
            });

            // Individual checkbox change
            $('.item-checkbox').change(function() {
                updateSelectedCount();

                // Update "Select All" checkbox state
                var allChecked = $('.item-checkbox:checked').length === $('.item-checkbox').length;
                $('#selectAll').prop('checked', allChecked);
            });
        });

        function updateSelectedCount() {
            var count = $('.item-checkbox:checked').length;
            $('#selectedCount').text(count);
            $('#removeSelectedBtn').prop('disabled', count === 0);
        }

        // USER STORY 1: Remove selected items 
        $('#removeSelectedBtn').click(function() {
            var selectedIds = [];

            // Collect all checked checkbox values
            $('.item-checkbox:checked').each(function() {
                selectedIds.push(parseInt($(this).val()));
            });

            console.log('Selected IDs:', selectedIds);

            if (selectedIds.length === 0) {
                alert('Please select items to remove.');
                return;
            }

            if (confirm('Are you sure you want to remove ' + selectedIds.length + ' item(s)?')) {
                $.ajax({
                    url: '@Url.Action("RemoveItems", "Inventory")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(selectedIds), // Send array directly
                    success: function(response) {
                        console.log('Response:', response);
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.log('Error:', error); 
                        alert('An error occurred while removing items: ' + error);
                    }
                });
            }
        });

        // USER STORY 3: Open adjust quantity modal
        function openAdjustQuantityModal(id, name, currentQuantity) {
            $('#adjustItemId').val(id);
            $('#adjustItemName').val(name);
            $('#adjustCurrentQuantity').val(currentQuantity);
            $('#adjustNewQuantity').val(currentQuantity);
            $('#adjustReason').val('');
            $('#adjustQuantityModal').modal('show');
        }

        // USER STORY 3: Submit quantity adjustment
        function submitQuantityAdjustment() {
            var id = $('#adjustItemId').val();
            var newQuantity = parseInt($('#adjustNewQuantity').val());
            var reason = $('#adjustReason').val();

            if (!newQuantity && newQuantity !== 0) {
                alert('Please enter a valid quantity.');
                return;
            }

            if (!reason || reason.trim() === '') {
                alert('Please provide a reason for the adjustment.');
                return;
            }

            $.ajax({
                url: '@Url.Action("AdjustQuantity", "Inventory")',
                type: 'POST',
                data: {
                    id: id,
                    newQuantity: newQuantity,
                    reason: reason
                },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        $('#adjustQuantityModal').modal('hide');
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('An error occurred while adjusting the quantity.');
                }
            });
        }
    </script>
}
