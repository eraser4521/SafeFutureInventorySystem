@model List<SafeFutureInventorySystem.Models.InventoryItem>
@{
    ViewData["Title"] = "Inventory List";
}

<div class="text-center">
    <h1 class="display-4">Sorted Inventory</h1>
    <p>Items sorted by date added (oldest to newest).</p>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Error))
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead class="thead-dark">
        <tr>
            <th>Name</th>
            <th>Quantity</th>
            <th>Date Added</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Quantity</td>
                <td>@item.DateAdded.ToShortDateString()</td>
            </tr>
        }
        </tbody>
    </table>
}