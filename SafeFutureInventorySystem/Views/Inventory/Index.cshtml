@model SafeFutureInventorySystem.Models.InventoryFilterViewModel

@{
    ViewBag.Title = "Inventory Management";
}

<!-- Success Message -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="close" data-dismiss="alert">
            <span>&times;</span>
        </button>
    </div>
}
<!-- ── Page Title ── -->
<div class="page-title-bar">
    <h2>Inventory Management</h2>
</div>

@{
    var hasActiveFilters = !string.IsNullOrWhiteSpace(Model.SearchTerm)
        || !string.IsNullOrWhiteSpace(Model.ExpirationFilter)
        || Model.FromDate.HasValue
        || Model.ToDate.HasValue;
}

<!-- ── Compact Filter Bar ── -->
<div class="filter-bar-card">
    <form method="get" asp-action="Index" id="filterForm">
        <div class="filter-row">

            <!-- Search -->
            <div class="filter-item">
                <label>Search</label>
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                    </div>
                    <input type="text" name="searchTerm" class="form-control"
                           placeholder="Name or description..."
                           value="@Model.SearchTerm" id="searchInput" />
                </div>
            </div>

            <!-- Status Filter -->
            <div class="filter-item">
                <label>Status</label>
                <select name="expirationFilter" class="form-control">
                    <option value="">All Items</option>
                    <option value="Expired" selected="@(Model.ExpirationFilter == "Expired")">Expired</option>
                    <option value="ExpiringSoon" selected="@(Model.ExpirationFilter == "ExpiringSoon")">Expiring Soon (7 days)</option>
                    <option value="ExpiringThisMonth" selected="@(Model.ExpirationFilter == "ExpiringThisMonth")">Expiring This Month</option>
                    <option value="Good" selected="@(Model.ExpirationFilter == "Good")">Good Condition</option>
                    <option value="NoExpiration" selected="@(Model.ExpirationFilter == "NoExpiration")">No Expiration</option>
                    <option value="LowStock" selected="@(Model.ExpirationFilter == "LowStock")">Low Stock</option>
                    <option value="NoStock" selected="@(Model.ExpirationFilter == "NoStock")">No Stock</option>
                </select>
            </div>

            <!-- From Date -->
            <div class="filter-item-sm">
                <label>From Date</label>
                <input type="date" name="fromDate" class="form-control"
                       value="@Model.FromDate?.ToString("yyyy-MM-dd")" />
            </div>

            <!-- To Date -->
            <div class="filter-item-sm">
                <label>To Date</label>
                <input type="date" name="toDate" class="form-control"
                       value="@Model.ToDate?.ToString("yyyy-MM-dd")" />
            </div>

            <!-- Items Per Page -->
            <div class="filter-item-xs">
                <label>Per Page</label>
                <select name="pageSize" class="form-control" onchange="this.form.submit()">
                    <option value="5" selected="@(Model.PageSize == 5)">5</option>
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="25" selected="@(Model.PageSize == 25)">25</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>

            <!-- Filter Button -->
            <div class="filter-btn">
                <label style="visibility:hidden;">Go</label>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-filter"></i> Filter
                </button>
            </div>

        </div>

        <input type="hidden" name="sortBy" value="@Model.SortBy" />
        <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
    </form>
</div>

<div class="inventory-toolbar-card">
    <div class="inventory-toolbar-top">
        <div class="inventory-results-meta">
            Showing @((Model.PageNumber - 1) * Model.PageSize + 1) to
            @(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount))
            of @Model.TotalCount items
        </div>

        @if (hasActiveFilters)
        {
            <div class="inventory-active-filters">
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <span class="inventory-filter-chip"><i class="fas fa-search"></i> @Model.SearchTerm</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.ExpirationFilter))
                {
                    <span class="inventory-filter-chip"><i class="fas fa-filter"></i> @Model.ExpirationFilter</span>
                }
                @if (Model.FromDate.HasValue || Model.ToDate.HasValue)
                {
                    <span class="inventory-filter-chip"><i class="fas fa-calendar-alt"></i> Date Window</span>
                }
                <a asp-action="Index" asp-route-pageSize="@Model.PageSize" class="inventory-clear-link">Clear filters</a>
            </div>
        }
    </div>

    <div class="inventory-toolbar-actions">
        <div class="inventory-action-group">
            <span class="inventory-action-group-label">Inventory</span>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Add New Item
            </a>
        </div>

        <div class="inventory-action-group">
            <span class="inventory-action-group-label">Selected Items</span>
            @if (User.IsInRole("Admin"))
            {
                <button type="button" class="btn btn-danger" id="removeSelectedBtn" disabled>
                    <i class="fas fa-trash"></i> Remove Selected (<span id="selectedCount">0</span>)
                </button>
            }

            <button type="button" class="btn btn-secondary" id="printQrLabelsBtn" disabled>
                <i class="fas fa-qrcode"></i> Print Selected QR Labels (<span id="qrSelectedCount">0</span>)
            </button>

            <button type="button" class="btn btn-danger" id="exportSelectedPdfBtn" disabled>
                <i class="fas fa-file-pdf"></i> Export Selected PDF (<span id="pdfSelectedCount">0</span>)
            </button>
        </div>
    </div>
</div>

    <!-- Inventory Table -->
    <div class="card inventory-table-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="inventoryTable">
                    <thead class="thead-dark">
                        <tr>
                            <th>
                                <input type="checkbox" id="selectAll" />
                            </th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-sortBy="Name"
                                   asp-route-sortOrder="@(Model.SortBy == "Name" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Name
                                    @if (Model.SortBy == "Name")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>Description</th>
                            <th>Donor</th> <!-- NEW DONOR COLUMN -->
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-sortBy="Quantity"
                                   asp-route-sortOrder="@(Model.SortBy == "Quantity" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Quantity
                                    @if (Model.SortBy == "Quantity")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-sortBy="DateAdded"
                                   asp-route-sortOrder="@(Model.SortBy == "DateAdded" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Date Added
                                    @if (Model.SortBy == "DateAdded")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>
                                <a asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-sortBy="ExpirationDate"
                                   asp-route-sortOrder="@(Model.SortBy == "ExpirationDate" && Model.SortOrder == "asc" ? "desc" : "asc")">
                                    Expiration Date
                                    @if (Model.SortBy == "ExpirationDate")
                                    {
                                        <i class="fas fa-sort-@(Model.SortOrder == "asc" ? "up" : "down")"></i>
                                    }
                                </a>
                            </th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var item in Model.Items)
                            {
                                <tr data-item-id="@item.Id">
                                    <td class="inventory-status-cell">
                                        <input type="checkbox" class="item-checkbox" value="@item.Id" />
                                    </td>
                                    <td class="inventory-name-cell">
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           asp-route-searchTerm="@Model.SearchTerm"
                                           asp-route-expirationFilter="@Model.ExpirationFilter"
                                           asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                                           asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                                           asp-route-sortBy="@Model.SortBy"
                                           asp-route-sortOrder="@Model.SortOrder"
                                           asp-route-page="@Model.PageNumber"
                                           asp-route-pageSize="@Model.PageSize"
                                           class="inventory-name-link">
                                            @item.Name
                                        </a>
                                    </td>
                                    <td>@(item.Description ?? "N/A")</td>

                                    <!-- DONOR INFORMATION CELL — shows most recent donor from DonationLogs -->
                                    <td>
                                        @{
                                            var latestDonation = item.DonationLogs?
                                            .OrderByDescending(d => d.DonationDate)
                                            .FirstOrDefault();
                                        }
                                        @if (latestDonation != null && !string.IsNullOrEmpty(latestDonation.DonorName))
                                        {
                                            <div>
                                                <i class="fas fa-user text-primary"></i>
                                                <strong>@latestDonation.DonorName</strong>
                                            </div>
                                            @if (item.DonationLogs.Count > 1)
                                            {
                                                <small class="text-info">
                                                    <i class="fas fa-layer-group"></i> @item.DonationLogs.Count donors
                                                </small>
                                            }
                                         
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unknown</span>
                                        }
                                    </td>

                                    <td class="inventory-quantity-cell">
                                        <span class="badge badge-light text-dark">@item.Quantity</span>
                                        @if (item.Quantity <= 0)
                                        {
                                            <span class="inventory-stock-indicator inventory-stock-none" title="No Stock">
                                                <i class="fas fa-times-circle"></i>
                                            </span>
                                        }
                                        else if (item.IsLowStock)
                                        {
                                            <span class="inventory-stock-indicator inventory-stock-low" title="Low Stock">
                                                <i class="fas fa-exclamation-triangle"></i>
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @item.DateAdded.ToString("MM/dd/yyyy")
                                    </td>
                                    <td>
                                        @if (item.ExpirationDate.HasValue)
                                        {
                                            @item.ExpirationDate.Value.ToString("MM/dd/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Expiration</span>
                                        }
                                    </td>
                                    <td class="inventory-status-cell">
                                        @if (item.Quantity <= 0)
                                        {
                                            <div class="mb-1">
                                                <span class="badge badge-danger inventory-status-badge">
                                                    <i class="fas fa-times-circle"></i> No Stock
                                                </span>
                                            </div>
                                        }
                                        @if (item.IsLowStock)
                                        {
                                            <div class="mb-1">
                                                <span class="badge badge-warning text-dark inventory-status-badge">
                                                    <i class="fas fa-exclamation-circle"></i> Low Stock
                                                </span>
                                            </div>
                                        }
                                        @{
                                            var bgClass = "";
                                            var textClass = "text-white";
                                            var statusIcon = "";
                                            switch (item.ExpirationStatus)
                                            {
                                                case "Expired":
                                                    bgClass = "bg-danger";
                                                    statusIcon = "fa-times-circle";
                                                    break;
                                                case "Expiring Soon":
                                                    bgClass = "bg-warning";
                                                    textClass = "text-dark";
                                                    statusIcon = "fa-exclamation-triangle";
                                                    break;
                                                case "Expiring This Month":
                                                    bgClass = "bg-warning";
                                                    textClass = "text-dark";
                                                    statusIcon = "fa-clock";
                                                    break;
                                                case "Good":
                                                    bgClass = "bg-success";
                                                    statusIcon = "fa-check-circle";
                                                    break;
                                                default:
                                                    bgClass = "bg-secondary";
                                                    statusIcon = "fa-infinity";
                                                    break;
                                            }
                                        }
                                        <span class="badge @bgClass @textClass inventory-status-badge">
                                            <i class="fas @statusIcon"></i> @item.ExpirationStatus
                                        </span>
                                    </td>
                                    <td class="inventory-actions-cell">
                                        <!-- View Details Button -->
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           asp-route-searchTerm="@Model.SearchTerm"
                                           asp-route-expirationFilter="@Model.ExpirationFilter"
                                           asp-route-fromDate="@Model.FromDate?.ToString("yyyy-MM-dd")"
                                           asp-route-toDate="@Model.ToDate?.ToString("yyyy-MM-dd")"
                                           asp-route-sortBy="@Model.SortBy"
                                           asp-route-sortOrder="@Model.SortOrder"
                                           asp-route-page="@Model.PageNumber"
                                           asp-route-pageSize="@Model.PageSize"
                                           class="btn btn-sm btn-info inventory-row-action" title="View Details">
                                            <i class="fas fa-eye"></i><span class="action-label">Details</span>
                                        </a>
                                        <!-- QR Code Button -->
                                        <a asp-action="QrCode" asp-route-id="@item.Id" class="btn btn-sm btn-secondary inventory-row-action" title="View QR Code">
                                            <i class="fas fa-qrcode"></i><span class="action-label">QR</span>
                                        </a>
                                        <!-- USER STORY 3: Adjust Quantity Button -->
                                        <button type="button" class="btn btn-sm btn-warning inventory-row-action"
                                                onclick="openAdjustQuantityModal(@item.Id, '@item.Name', @item.Quantity)" title="Adjust Quantity">
                                            <i class="fas fa-edit"></i><span class="action-label">Adjust</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center">
                                    <!-- Changed from 8 to 9 for donor column -->
                                    <p class="text-muted">No items found matching your criteria.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Enhanced Pagination with Jump to Page -->
            @if (Model.TotalPages > 1)
            {
                <nav>
                    <ul class="pagination justify-content-center">
                        <!-- First Page -->
                        @if (Model.PageNumber > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="1">
                                    <i class="fas fa-angle-double-left"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.PageNumber - 1)">Previous</a>
                            </li>
                        }

                        <!-- Page Numbers (show 5 at a time) -->
                        @{
                            int startPage = Math.Max(1, Model.PageNumber - 2);
                            int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
                        }

                        @for (int i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@i">@i</a>
                            </li>
                        }

                        <!-- Next and Last -->
                        @if (Model.PageNumber < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@(Model.PageNumber + 1)">Next</a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-expirationFilter="@Model.ExpirationFilter"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-page="@Model.TotalPages">
                                    <i class="fas fa-angle-double-right"></i>
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- NEW: Jump to Page Feature -->
                    <div class="text-center mt-3">
                        <form method="get" asp-action="Index" class="form-inline justify-content-center" id="jumpToPageForm">
                            <input type="hidden" name="searchTerm" value="@Model.SearchTerm" />
                            <input type="hidden" name="expirationFilter" value="@Model.ExpirationFilter" />
                            <input type="hidden" name="sortBy" value="@Model.SortBy" />
                            <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
                            <input type="hidden" name="pageSize" value="@Model.PageSize" />

                            <label class="mr-2">Jump to page:</label>
                            <input type="number" name="page" class="form-control form-control-sm"
                                   min="1" max="@Model.TotalPages" value="@Model.PageNumber"
                                   style="width: 80px;" />
                            <button type="submit" class="btn btn-sm btn-primary ml-2">Go</button>
                        </form>
                    </div>
                </nav>
            }
        </div>
    </div>
</div>

<!-- USER STORY 3: Adjust Quantity Modal -->
<div class="modal fade" id="adjustQuantityModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Adjust Quantity</h5>
                <button type="button" class="close adjust-close" data-dismiss="modal" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="adjustQuantityForm">
                    <input type="hidden" id="adjustItemId" />

                    <div class="form-group">
                        <label>Item Name:</label>
                        <input type="text" class="form-control" id="adjustItemName" readonly />
                    </div>

                    <div class="form-group">
                        <label>Current Quantity:</label>
                        <input type="number" class="form-control" id="adjustCurrentQuantity" readonly />
                    </div>

                    <div class="form-group">
                        <label for="adjustNewQuantity">New Quantity: <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="adjustNewQuantity"
                               min="0" required />
                        <small class="form-text text-muted">Only positive numbers allowed</small>
                    </div>

                    <div class="form-group">
                        <label for="adjustReason">Reason for Adjustment: <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="adjustReason" rows="3"
                                  placeholder="E.g., Physical stock check, damaged items, etc." required></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary adjust-cancel" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitQuantityAdjustment()">
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/js/all.min.js"></script>

    <script>
        const inventoryRequestVerificationToken = document.querySelector('meta[name="request-verification-token"]')?.getAttribute('content');

        $(document).ready(function() {
            // Select All checkbox functionality
            $('#selectAll').change(function() {
                $('.item-checkbox').prop('checked', this.checked);
                updateSelectedCount();
            });

            // Individual checkbox change
            $('.item-checkbox').change(function() {
                updateSelectedCount();

                // Update "Select All" checkbox state
                var allChecked = $('.item-checkbox:checked').length === $('.item-checkbox').length;
                $('#selectAll').prop('checked', allChecked);
            });
        });

        function getSelectedItemIds() {
            var selectedIds = [];

            $('.item-checkbox:checked').each(function() {
                selectedIds.push(parseInt($(this).val()));
            });

            return selectedIds;
        }

        function updateSelectedCount() {
            var count = $('.item-checkbox:checked').length;
            $('#selectedCount').text(count);
            $('#qrSelectedCount').text(count);
            $('#pdfSelectedCount').text(count);
            $('#removeSelectedBtn').prop('disabled', count === 0);
            $('#printQrLabelsBtn').prop('disabled', count === 0);
            $('#exportSelectedPdfBtn').prop('disabled', count === 0);
        }

        // Ensure the adjust modal can always be closed
        $(document).on('click', '.adjust-close, .adjust-cancel', function() {
            $('#adjustQuantityModal').modal('hide');
        });

        // USER STORY 1: Remove selected items
        $('#removeSelectedBtn').click(function() {
            var selectedIds = getSelectedItemIds();

            if (selectedIds.length === 0) {
                alert('Please select items to remove.');
                return;
            }

            if (confirm('Are you sure you want to remove ' + selectedIds.length + ' item(s)?')) {
                $.ajax({
                    url: '@Url.Action("RemoveItems", "Inventory")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(selectedIds),
                    headers: { 'RequestVerificationToken': inventoryRequestVerificationToken },
                    success: function(response) {
                        if (response.success) {
                            alert(response.message);
                            location.reload();
                        } else {
                            alert('Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        alert('An error occurred while removing items: ' + error);
                    }
                });
            }
        });

                // Table "Export to PDF" → exports only selected items
        $('#exportSelectedPdfBtn').click(function () {
            var selectedIds = getSelectedItemIds();

            if (selectedIds.length === 0) {
                alert('Please select at least one item to export.');
                return;
            }

            var btn = document.getElementById('exportSelectedPdfBtn');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Generating...';
            btn.disabled = true;

            $.ajax({
                url: '@Url.Action("ExportSelectedItemsPdf", "Inventory")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(selectedIds),
                headers: { 'RequestVerificationToken': inventoryRequestVerificationToken },
                xhrFields: { responseType: 'blob' },
                success: function (data) {
                    var url = window.URL.createObjectURL(data);
                    var a = document.createElement('a');
                    a.href = url;
                    a.download = 'Selected_Items_' + new Date().toISOString().slice(0, 10) + '.pdf';
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                    btn.innerHTML = '<i class="fas fa-file-pdf"></i> Export Selected PDF (<span id="pdfSelectedCount">' + selectedIds.length + '</span>)';
                    btn.disabled = false;
                },
                error: function () {
                    alert('Error generating PDF. Please try again.');
                    btn.innerHTML = '<i class="fas fa-file-pdf"></i> Export Selected PDF (<span id="pdfSelectedCount">' + selectedIds.length + '</span>)';
                    btn.disabled = false;
                }
            });
        });

        $('#printQrLabelsBtn').click(function () {
            var selectedIds = getSelectedItemIds();

            if (selectedIds.length === 0) {
                alert('Please select at least one item to print QR labels.');
                return;
            }

            var query = selectedIds.map(function(id) {
                return 'ids=' + encodeURIComponent(id);
            }).join('&');

            window.location.href = '@Url.Action("BatchLabels", "QRCodes")' + '?' + query;
        });

        // Export to CSV
        $('#exportCsvBtn').click(function() {
            var searchTerm = '@Model.SearchTerm';
            var expirationFilter = '@Model.ExpirationFilter';
            var fromDate = '@Model.FromDate?.ToString("yyyy-MM-dd")';
            var toDate = '@Model.ToDate?.ToString("yyyy-MM-dd")';
            var sortBy = '@Model.SortBy';
            var sortOrder = '@Model.SortOrder';

            var url = '@Url.Action("ExportInventoryCsv", "Inventory")' +
                '?searchTerm=' + encodeURIComponent(searchTerm) +
                '&expirationFilter=' + encodeURIComponent(expirationFilter) +
                '&fromDate=' + encodeURIComponent(fromDate) +
                '&toDate=' + encodeURIComponent(toDate) +
                '&sortBy=' + encodeURIComponent(sortBy) +
                '&sortOrder=' + encodeURIComponent(sortOrder);

            window.location.href = url;
        });

        $('#exportExcelBtn').click(function() {
            window.location.href = '@Url.Action("ExportInventoryExcel", "Inventory")';
        });

        // USER STORY 3: Open adjust quantity modal
        function openAdjustQuantityModal(id, name, currentQuantity) {
            $('#adjustItemId').val(id);
            $('#adjustItemName').val(name);
            $('#adjustCurrentQuantity').val(currentQuantity);
            $('#adjustNewQuantity').val(currentQuantity);
            $('#adjustReason').val('');
            $('#adjustQuantityModal').modal('show');
        }

        // USER STORY 3 & 7: Submit quantity adjustment with validation
        function submitQuantityAdjustment() {
            var id = $('#adjustItemId').val();
            var newQuantity = parseInt($('#adjustNewQuantity').val());
            var reason = $('#adjustReason').val();

            // Validation
            if (isNaN(newQuantity) || newQuantity < 0) {
                alert('Please enter a valid non-negative quantity.');
                return;
            }

            if (!reason || reason.trim() === '') {
                alert('Please provide a reason for the adjustment.');
                return;
            }

            $.ajax({
                url: '@Url.Action("AdjustQuantity", "Inventory")',
                type: 'POST',
                data: {
                    id: id,
                    newQuantity: newQuantity,
                    reason: reason
                },
                headers: { 'RequestVerificationToken': inventoryRequestVerificationToken },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        $('#adjustQuantityModal').modal('hide');
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                },
                error: function() {
                    alert('An error occurred while adjusting the quantity.');
                }
            });
        }

        // USER STORY 7: Prevent non-numeric characters in quantity field
        document.getElementById('adjustNewQuantity').addEventListener('keypress', function(e) {
            // Only allow numbers (0-9)
            if (e.which < 48 || e.which > 57) {
                e.preventDefault();
                return false;
            }
        });

        // Prevent negative numbers in real-time
        document.getElementById('adjustNewQuantity').addEventListener('input', function(e) {
            if (this.value < 0) {
                this.value = 0;
            }
        });

        // Validate jump to page input
        document.querySelector('input[name="page"]').addEventListener('input', function() {
            var max = parseInt(this.getAttribute('max'));
            if (parseInt(this.value) > max) {
                this.value = max;
            }
            if (parseInt(this.value) < 1) {
                this.value = 1;
            }
        });
    </script>
}
