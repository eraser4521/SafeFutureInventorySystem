@model SafeFutureInventorySystem.Models.InventoryItem

@{
    ViewBag.Title = "Edit Item";
    var returnSearchTerm = ViewBag.ReturnSearchTerm as string;
    var returnExpirationFilter = ViewBag.ReturnExpirationFilter as string;
    var returnFromDate = ViewBag.ReturnFromDate as DateTime?;
    var returnToDate = ViewBag.ReturnToDate as DateTime?;
    var returnSortBy = ViewBag.ReturnSortBy as string ?? "Name";
    var returnSortOrder = ViewBag.ReturnSortOrder as string ?? "asc";
    var returnPage = ViewBag.ReturnPage is int pageNumber ? pageNumber : 1;
    var returnPageSize = ViewBag.ReturnPageSize is int pageSize ? pageSize : 10;
}

<div class="details-page-title">
    <h2>Edit Item</h2>
</div>

<div class="container details-container">
    <div class="card">
        <div class="card-header bg-warning text-dark">
            <h5 class="mb-0"><i class="fas fa-edit"></i> Update Item Metadata</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" class="metadata-edit-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="searchTerm" value="@returnSearchTerm" />
                <input type="hidden" name="expirationFilter" value="@returnExpirationFilter" />
                <input type="hidden" name="fromDate" value="@returnFromDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="toDate" value="@returnToDate?.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="sortBy" value="@returnSortBy" />
                <input type="hidden" name="sortOrder" value="@returnSortOrder" />
                <input type="hidden" name="page" value="@returnPage" />
                <input type="hidden" name="pageSize" value="@returnPageSize" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row">
                    <div class="col-lg-6">
                        <div class="form-group">
                            <label asp-for="Name" class="control-label">Item Name <span class="required-marker">*</span></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description" class="control-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Category" class="control-label">Category</label>
                            <select asp-for="Category" class="form-control">
                                <option value="">-- Select Category --</option>
                                <option value="Diapers">Diapers</option>
                                <option value="Baby Wipes">Baby Wipes</option>
                                <option value="Baby Formula">Baby Formula</option>
                                <option value="Baby Food">Baby Food</option>
                                <option value="Feeding">Feeding</option>
                                <option value="Clothing">Clothing</option>
                                <option value="Baby Care">Baby Care</option>
                                <option value="Diapering">Diapering</option>
                                <option value="Baby Health">Baby Health</option>
                                <option value="Bathing">Bathing</option>
                                <option value="Bedding">Bedding</option>
                                <option value="Safety">Safety</option>
                                <option value="Accessories">Accessories</option>
                                <option value="Comfort">Comfort</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-lg-6">
                        <div class="form-group">
                            <label asp-for="Quantity" class="control-label">Quantity <span class="required-marker">*</span></label>
                            <input asp-for="Quantity" class="form-control" type="number" min="0" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="ExpirationDate" class="control-label">Expiration Date</label>
                            <input asp-for="ExpirationDate" class="form-control" type="date" />
                            <span asp-validation-for="ExpirationDate" class="text-danger"></span>
                            <small class="form-text text-muted">Leave blank if this item does not expire.</small>
                        </div>

                        <div class="form-group">
                            <label asp-for="LowStockThreshold" class="control-label">Low-Stock Threshold</label>
                            <input asp-for="LowStockThreshold" class="form-control" type="number" min="0" />
                            <span asp-validation-for="LowStockThreshold" class="text-danger"></span>
                            <small class="form-text text-muted">Set to 0 to disable low-stock alerts for this item.</small>
                        </div>

                        <div class="metadata-readonly-block">
                            <div class="metadata-readonly-item">
                                <span class="metadata-readonly-label">Date Added</span>
                                <span>@Model.DateAdded.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="metadata-readonly-item">
                                <span class="metadata-readonly-label">Last Updated</span>
                                <span>@(Model.LastUpdated?.ToString("MMM dd, yyyy h:mm tt") ?? "Never")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="metadata-edit-actions">
                    <a asp-action="Details"
                       asp-route-id="@Model.Id"
                       asp-route-searchTerm="@returnSearchTerm"
                       asp-route-expirationFilter="@returnExpirationFilter"
                       asp-route-fromDate="@returnFromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@returnToDate?.ToString("yyyy-MM-dd")"
                       asp-route-sortBy="@returnSortBy"
                       asp-route-sortOrder="@returnSortOrder"
                       asp-route-page="@returnPage"
                       asp-route-pageSize="@returnPageSize"
                       class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
