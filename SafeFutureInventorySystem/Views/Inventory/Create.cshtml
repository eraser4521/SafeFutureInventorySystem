@model SafeFutureInventorySystem.Models.InventoryItem

@{
    ViewBag.Title = "Add New Inventory Item";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3><i class="fas fa-plus-circle"></i> Add New Inventory Item</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <!-- ITEM INFORMATION SECTION -->
                            <div class="col-md-6">
                                <h4 class="mb-3"><i class="fas fa-box"></i> Item Information</h4>

                                <div class="form-group">
                                    <label asp-for="Name" class="control-label">
                                        Item Name <span class="text-danger">*</span>
                                    </label>
                                    <div class="position-relative">
                                        <input asp-for="Name" id="itemNameInput" class="form-control"
                                               placeholder="e.g., Pampers Size 3 Diapers"
                                               autocomplete="off" required />
                                        <!-- Suggestion dropdown rendered here by JS -->
                                        <ul id="nameSuggestions"
                                            class="list-group shadow"
                                            style="display:none; position:absolute; z-index:1000;
                                            width:100%; max-height:260px; overflow-y:auto;
                                            top:100%; left:0;"></ul>
                                    </div>
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                    <small id="mergeWarning" class="text-warning font-weight-bold" style="display:none;">
                                        <i class="fas fa-exclamation-triangle"></i>
                                        An item with this name already exists — submitting will merge the quantity into it.
                                    </small>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Description" class="control-label">Description</label>
                                    <textarea asp-for="Description" class="form-control" rows="3"
                                              placeholder="Detailed description of the item"></textarea>
                                    <span asp-validation-for="Description" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Category" class="control-label">Category</label>
                                    <select asp-for="Category" class="form-control">
                                        <option value="">-- Select Category --</option>
                                        <option value="Diapers">Diapers</option>
                                        <option value="Baby Wipes">Baby Wipes</option>
                                        <option value="Baby Formula">Baby Formula</option>
                                        <option value="Baby Food">Baby Food</option>
                                        <option value="Feeding">Feeding</option>
                                        <option value="Clothing">Clothing</option>
                                        <option value="Baby Care">Baby Care</option>
                                        <option value="Diapering">Diapering</option>
                                        <option value="Baby Health">Baby Health</option>
                                        <option value="Bathing">Bathing</option>
                                        <option value="Bedding">Bedding</option>
                                        <option value="Safety">Safety</option>
                                        <option value="Accessories">Accessories</option>
                                        <option value="Comfort">Comfort</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="Quantity" class="control-label">Quantity <span class="text-danger">*</span></label>
                                            <input asp-for="Quantity" class="form-control" type="number" min="1"
                                                   placeholder="0" required />
                                            <span asp-validation-for="Quantity" class="text-danger"></span>
                                            <small class="form-text text-muted">Must be a positive number</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label asp-for="ExpirationDate" class="control-label">Expiration Date</label>
                                    <input asp-for="ExpirationDate" class="form-control" type="date" />
                                    <span asp-validation-for="ExpirationDate" class="text-danger"></span>
                                    <small class="form-text text-muted">Leave blank if no expiration</small>
                                </div>
                            </div>

                            <!-- DONOR INFORMATION SECTION -->
                            <!-- These use plain name="" attributes — NOT asp-for -->
                            <!-- They are received as separate parameters in the controller -->
                            <div class="col-md-6">
                                <h4 class="mb-3"><i class="fas fa-user-plus"></i> Donor Information</h4>

                                <div class="form-group">
                                    <label class="control-label">Donor Name</label>
                                    <input type="text" name="DonorName" class="form-control"
                                           placeholder="Enter donor's full name or organization" />
                                </div>
                                <div class="alert alert-info mt-3" style="display: block; font-size: 0.9rem; line-height: 1.6;">
                                    <p class="mb-0">
                                        <i class="fas fa-info-circle"></i>
                                        <strong>Duplicate Detection:</strong> If an item with the same <strong>name</strong> already exists, 
                                        this donation will be merged into the existing stock automatically — no duplicate entry will be created.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="form-group text-right">
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-save"></i> Add Item
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.querySelector('input[name="Quantity"]').addEventListener('keypress', function(e) {
            if (e.which < 48 || e.which > 57) {
                e.preventDefault();
                return false;
            }
        });

        document.querySelector('input[name="Quantity"]').addEventListener('input', function(e) {
            if (this.value < 0) {
                this.value = 0;
            }
        });

        // ── Live name autocomplete with merge warning ──────────────────────────
        (function () {
            const input       = document.getElementById('itemNameInput');
            const dropdown    = document.getElementById('nameSuggestions');
            const mergeWarn   = document.getElementById('mergeWarning');
            let debounceTimer = null;
            let suppressBlur  = false;

            function clearDropdown() {
                dropdown.innerHTML = '';
                dropdown.style.display = 'none';
            }

            function checkExactMatch(name) {
                // Show merge warning if typed name exactly matches a suggestion label
                const items = dropdown.querySelectorAll('li[data-name]');
                let exact = false;
                items.forEach(li => {
                    if (li.dataset.name.toLowerCase() === name.toLowerCase()) exact = true;
                });
                mergeWarn.style.display = exact ? 'inline-block' : 'none';
            }

            function fetchSuggestions(term) {
                if (!term || term.length < 2) {
                    clearDropdown();
                    mergeWarn.style.display = 'none';
                    return;
                }

                fetch('/Inventory/SearchItems?term=' + encodeURIComponent(term))
                    .then(r => r.json())
                    .then(results => {
                        clearDropdown();
                        if (!results || results.length === 0) {
                            mergeWarn.style.display = 'none';
                            return;
                        }

                        results.forEach(item => {
                            const li = document.createElement('li');
                            li.className = 'list-group-item list-group-item-action py-2 px-3';
                            li.dataset.name = item.label;
                                li.innerHTML =
                                `<div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>${item.label}</strong>
                                        <small class="text-muted ml-2">${item.category}</small>
                                    </div>
                                    <span class="badge badge-primary badge-pill">${item.quantity} units</span>
                                </div>`;
                                

                            li.addEventListener('mousedown', () => { suppressBlur = true; });
                            li.addEventListener('click', () => {
                                input.value = item.label;
                                clearDropdown();
                                mergeWarn.style.display = 'inline-block';
                                suppressBlur = false;
                                input.focus();
                            });

                            dropdown.appendChild(li);
                        });

                        dropdown.style.display = 'block';
                        checkExactMatch(term);
                    })
                    .catch(() => clearDropdown());
            }

            input.addEventListener('input', function () {
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(() => fetchSuggestions(this.value.trim()), 250);
            });

            input.addEventListener('keydown', function (e) {
                const items = dropdown.querySelectorAll('li');
                const active = dropdown.querySelector('li.active');
                let idx = Array.from(items).indexOf(active);

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if (active) active.classList.remove('active');
                    const next = items[Math.min(idx + 1, items.length - 1)];
                    if (next) next.classList.add('active');
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if (active) active.classList.remove('active');
                    const prev = items[Math.max(idx - 1, 0)];
                    if (prev) prev.classList.add('active');
                } else if (e.key === 'Enter' && active) {
                    e.preventDefault();
                    input.value = active.dataset.name;
                    clearDropdown();
                    mergeWarn.style.display = 'inline-block';
                } else if (e.key === 'Escape') {
                    clearDropdown();
                }
            });

            input.addEventListener('blur', function () {
                if (!suppressBlur) {
                    setTimeout(clearDropdown, 150);
                }
                suppressBlur = false;
            });

            // Re-check merge warning when user manually finishes typing
            input.addEventListener('change', function () {
                checkExactMatch(this.value.trim());
            });
        })();

    </script>
}
