@model SafeFutureInventorySystem.Models.InventoryItem
@{
    ViewData["Title"] = "Generate QR Code";
}

<div class="text-center">
    <h2>Generate QR Code for @Model.Name</h2>
    <p>Quantity: @Model.Quantity</p>
    <img src="@Url.Action("ImageForItem","QRCodes", new { inventoryItemId = Model.Id })" alt="QR Code for @Model.Name" />

    <form asp-action="Create" method="post" class="mt-3">
        <input type="hidden" name="inventoryItemId" value="@Model.Id" />
        <button class="btn btn-primary" type="submit">Save QR Code</button>
        <a class="btn btn-secondary" href="@Url.Action("Index","QRCodes")">Cancel</a>
    </form>
</div>