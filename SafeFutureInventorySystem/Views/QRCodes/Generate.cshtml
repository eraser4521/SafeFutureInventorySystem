@model SafeFutureInventorySystem.Models.InventoryItem
@{
    ViewData["Title"] = "Generate QR Code";
}

<div class="text-center">
    <h2>QR Code for @Model.Name</h2>
    <p>Quantity: @Model.Quantity</p>
    <img src="@Url.Action("ImageForItem","QRCodes", new { inventoryItemId = Model.Id })" alt="QR Code for @Model.Name" />

    <div class="mt-3">
        <a class="btn btn-info" href="@Url.Action("ImageForItem","QRCodes", new { inventoryItemId = Model.Id })" download="qrcode_@(Model.Id).png">Download QR Code</a>
        <a class="btn btn-secondary" href="@Url.Action("Details","Inventory", new { id = Model.Id })">Back to Item</a>
    </div>
</div>