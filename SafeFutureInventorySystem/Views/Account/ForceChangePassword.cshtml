@{
    ViewData["Title"] = "Set Your Password";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 140px);">
    <div class="card shadow-lg border-0" style="width: 100%; max-width: 520px; border-radius: 18px;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold mb-2" style="color:#24364b;">Create Your Password</h2>
                <p class="text-muted mb-0">
                    Finish setting up your account by choosing a password.
                </p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="ForceChangePassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input class="form-control form-control-lg bg-light" value="@ViewBag.Email" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">New Password</label>
                    <input type="password" name="newPassword" class="form-control form-control-lg" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Confirm Password</label>
                    <input type="password" name="confirmPassword" class="form-control form-control-lg" required />
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100" style="border-radius:12px;">
                    Save Password
                </button>
            </form>
        </div>
    </div>
</div>