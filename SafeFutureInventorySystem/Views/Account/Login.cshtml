@{
    ViewData["Title"] = "Safe Future - Login";
    Layout = "_AuthLayout";
}

<div class="login-wrapper">
    <div class="login-card">

        <div class="login-left">
            <div class="content-middle">
                <img src="~/images/safefuturelogo.webp" class="logo-main" alt="Safe Future" />
                <div class="silver-line"></div>
                <h1>Welcome</h1>
                <p>Sign in to access the inventory management system.</p>
            </div>
        </div>

        <div class="login-right">
            <div class="content-middle right-content">
                <h2>Sign In</h2>
                <div class="blue-line"></div>

                @if (ViewBag.Error != null)
                {
                    <div class="error-alert">@ViewBag.Error</div>
                }

                <form method="post" asp-action="Login" asp-controller="Account">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                    <div class="field">
                        <label>Email Address</label>
                        <input name="email" type="email" placeholder="Email" required />
                    </div>

                    <div class="field">
                        <label>Password</label>
                        <input name="password" type="password" placeholder="Password" required />
                    </div>

                    <button type="submit" class="btn-primary">Sign In</button>
                </form>

                <div class="footer-text">
                    &copy; 2026 Safe Future Foundation.
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    * {
        box-sizing: border-box;
    }

    html, body {
        height: 100%;
        margin: 0;
    }

    :root {
        --sf-blue: #4A90E2;
        --sf-navy: #1a202c;
    }

    body {
        background: #f0f2f5;
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    .login-wrapper {
        min-height: 100dvh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 24px;
        transform: translateY(-50px);
    }

    .login-card {
        width: 100%;
        max-width: 1050px;
        height: 600px;
        display: flex;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    }

    .login-left,
    .login-right {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 60px;
        height: 100%;
    }

    .login-left {
        background: var(--sf-blue);
        color: white;
    }

    .content-middle {
        width: 100%;
        max-width: 360px;
    }

    .login-left .content-middle {
        transform: translateY(-60px);
    }

    .right-content {
        display: flex;
        flex-direction: column;
        gap: 8px;
        transform: translateY(5px);
    }

    .logo-main {
        width: 250px;
        margin-bottom: 20px;
    }

    .silver-line {
        width: 40px;
        height: 4px;
        background: rgba(255,255,255,0.3);
        margin-bottom: 18px;
        border-radius: 2px;
    }

    h1 {
        font-size: 3.2rem;
        font-weight: 800;
        margin: 0 0 8px 0;
        letter-spacing: -2px;
    }

    .login-left p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.45;
        color: rgba(255,255,255,0.95);
        max-width: 300px;
    }

    h2 {
        font-size: 2.2rem;
        font-weight: 700;
        margin: 0 0 4px 0;
        color: var(--sf-navy);
    }

    .blue-line {
        width: 40px;
        height: 4px;
        background: var(--sf-blue);
        margin-bottom: 12px;
        border-radius: 2px;
    }

    .field {
        margin-bottom: 10px;
    }

    .field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #718096;
        margin-bottom: 6px;
    }

    input {
        width: 100%;
        height: 50px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0 15px;
        font-size: 1rem;
        transition: 0.2s;
    }

    input:focus {
        outline: none;
        border-color: var(--sf-blue);
        background: white;
        box-shadow: 0 0 0 4px rgba(74, 144, 226, 0.1);
    }

    .btn-primary {
        width: 100%;
        height: 54px;
        background: var(--sf-blue);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        margin-top: 4px;
    }

    .btn-primary:hover {
        background: #3f7fd1;
    }

    .footer-text {
        margin-top: 10px;
        font-size: 0.75rem;
        color: #a0aec0;
        text-align: center;
    }

    .error-alert {
        background: #fff5f5;
        color: #c53030;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 8px;
        border: 1px solid #feb2b2;
        font-size: 0.85rem;
    }

    @@media (max-width: 900px) {
        html, body {
            height: auto;
            min-height: 100%;
        }

        body {
            overflow-y: auto;
        }

        .login-card {
            flex-direction: column;
            height: auto;
            width: min(100%, 780px);
            max-width: none;
        }

        .login-left,
        .login-right {
            padding: clamp(28px, 5vw, 42px) clamp(20px, 4vw, 36px);
            height: auto;
        }

        .login-wrapper {
            transform: none;
            width: 100%;
            padding: clamp(6px, 1.8vw, 10px);
            min-height: auto;
        }

        .login-left .content-middle,
        .right-content {
            transform: none;
            width: 100%;
            max-width: min(520px, 100%);
            margin: 0 auto;
        }

        .content-middle {
            max-width: 100%;
        }

        .login-left {
            min-height: clamp(200px, 28vh, 260px);
        }

        .login-left .content-middle {
            align-items: center;
            text-align: center;
        }

        .silver-line {
            margin-left: auto;
            margin-right: auto;
        }

        .login-left p {
            max-width: 420px;
            margin-left: auto;
            margin-right: auto;
        }
    }

    @@media (max-width: 770px) {
        .login-wrapper {
            padding: clamp(4px, 1.5vw, 8px);
        }

        .login-card {
            width: 100%;
        }

        .login-left,
        .login-right {
            padding: clamp(22px, 4vw, 30px) clamp(16px, 3.5vw, 26px);
        }

        .logo-main {
            width: clamp(170px, 30vw, 190px);
            margin-bottom: 12px;
        }

        .login-left .content-middle {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .login-left {
            min-height: clamp(190px, 26vh, 230px);
        }

        h1 {
            font-size: clamp(2.1rem, 5vw, 2.5rem);
            line-height: 1.05;
            margin-bottom: 8px;
        }

        .login-left p {
            font-size: clamp(0.9rem, 1.8vw, 0.95rem);
            max-width: 340px;
        }

        h2 {
            font-size: clamp(1.8rem, 4vw, 2rem);
        }

        .field {
            margin-bottom: 8px;
        }

        .footer-text {
            margin-top: 8px;
        }
    }

    @@media (max-width: 576px) {
        .login-wrapper {
            display: block;
            padding: clamp(2px, 1vw, 4px);
        }

        .login-card {
            width: 100%;
            max-width: none;
            border-radius: 18px;
            box-shadow: 0 14px 32px rgba(0,0,0,0.12);
        }

        .login-left,
        .login-right {
            padding: clamp(18px, 3.5vh, 20px) clamp(14px, 4vw, 16px);
        }

        .login-left {
            text-align: center;
            min-height: auto;
        }

        .login-left .content-middle {
            align-items: center;
        }

        .login-left p {
            max-width: none;
        }

        .logo-main {
            width: min(160px, 56vw);
            margin-bottom: 10px;
        }

        .silver-line {
            margin-left: auto;
            margin-right: auto;
        }

        .blue-line {
            margin-left: 0;
            margin-right: 0;
        }

        h1 {
            font-size: clamp(1.75rem, 7vw, 1.95rem);
            letter-spacing: -1px;
        }

        h2 {
            font-size: clamp(1.6rem, 6vw, 1.75rem);
        }

        .login-left p {
            max-width: 280px;
            margin-left: auto;
            margin-right: auto;
            font-size: clamp(0.88rem, 3.4vw, 0.94rem);
        }

        .field {
            margin-bottom: 10px;
        }

        input {
            height: 46px;
            font-size: 16px;
        }

        .btn-primary {
            height: 48px;
        }

        .footer-text {
            margin-top: 10px;
        }
    }

    @@media (max-width: 576px) and (max-height: 700px) {
        .login-left,
        .login-right {
            padding-top: 16px;
            padding-bottom: 16px;
        }

        .login-left {
            min-height: 180px;
        }

        .logo-main {
            width: min(148px, 52vw);
            margin-bottom: 8px;
        }

        h1 {
            font-size: 1.7rem;
        }

        .login-left p {
            font-size: 0.86rem;
        }

        input {
            height: 44px;
        }

        .btn-primary {
            height: 46px;
        }

        .footer-text {
            margin-top: 8px;
        }
    }
</style>
