@{
    ViewData["Title"] = "Safe Future - Login";
    Layout = "_AuthLayout";
}

<div class="login-wrapper">
    <div class="login-card">

        <div class="login-left">
            <div class="content-middle">
                <img src="~/images/safefuturelogo.webp" class="logo-main" alt="Safe Future" />
                <div class="silver-line"></div>
                <h1>Welcome</h1>
                <p>Sign in to access the inventory management system.</p>
            </div>
        </div>

        <div class="login-right">
            <div class="content-middle right-content">
                <h2>Sign In</h2>
                <div class="blue-line"></div>

                @if (ViewBag.Error != null)
                {
                    <div class="error-alert">@ViewBag.Error</div>
                }

                <form method="post" asp-action="Login" asp-controller="Account">
                    <div class="field">
                        <label>Email Address</label>
                        <input name="email" type="email" placeholder="Email" required />
                    </div>

                    <div class="field">
                        <label>Password</label>
                        <input name="password" type="password" placeholder="Password" required />
                    </div>

                    <button type="submit" class="btn-primary">Sign In</button>
                </form>

                <div class="footer-text">
                    &copy; 2026 Safe Future Foundation.
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    * {
        box-sizing: border-box;
    }

    html, body {
        height: 100%;
        margin: 0;
        overflow: hidden;
    }

    :root {
        --sf-blue: #4A90E2;
        --sf-navy: #1a202c;
    }

    body {
        background: #f0f2f5;
        font-family: 'Inter', 'Segoe UI', sans-serif;
    }

    .login-wrapper {
        height: 100dvh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0;
        transform: translateY(-50px);
        overflow: hidden;
    }

    .login-card {
        width: 100%;
        max-width: 1050px;
        height: 600px;
        display: flex;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    }

    .login-left,
    .login-right {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 60px;
        height: 100%;
    }

    .login-left {
        background: var(--sf-blue);
        color: white;
    }

    .content-middle {
        width: 100%;
        max-width: 360px;
    }

    .login-left .content-middle {
        transform: translateY(-60px);
    }

    .right-content {
        display: flex;
        flex-direction: column;
        gap: 8px;
        transform: translateY(5px);
    }

    .logo-main {
        width: 250px;
        margin-bottom: 20px;
    }

    .silver-line {
        width: 40px;
        height: 4px;
        background: rgba(255,255,255,0.3);
        margin-bottom: 18px;
        border-radius: 2px;
    }

    h1 {
        font-size: 3.2rem;
        font-weight: 800;
        margin: 0 0 8px 0;
        letter-spacing: -2px;
    }

    .login-left p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.45;
        color: rgba(255,255,255,0.95);
        max-width: 300px;
    }

    h2 {
        font-size: 2.2rem;
        font-weight: 700;
        margin: 0 0 4px 0;
        color: var(--sf-navy);
    }

    .blue-line {
        width: 40px;
        height: 4px;
        background: var(--sf-blue);
        margin-bottom: 12px;
        border-radius: 2px;
    }

    .field {
        margin-bottom: 10px;
    }

    .field label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #718096;
        margin-bottom: 6px;
    }

    input {
        width: 100%;
        height: 50px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0 15px;
        font-size: 1rem;
        transition: 0.2s;
    }

    input:focus {
        outline: none;
        border-color: var(--sf-blue);
        background: white;
        box-shadow: 0 0 0 4px rgba(74, 144, 226, 0.1);
    }

    .btn-primary {
        width: 100%;
        height: 54px;
        background: var(--sf-blue);
        color: white;
        border: none;
        border-radius: 10px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        margin-top: 4px;
    }

    .btn-primary:hover {
        background: #3f7fd1;
    }

    .footer-text {
        margin-top: 10px;
        font-size: 0.75rem;
        color: #a0aec0;
        text-align: center;
    }

    .error-alert {
        background: #fff5f5;
        color: #c53030;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 8px;
        border: 1px solid #feb2b2;
        font-size: 0.85rem;
    }

    @@media (max-width: 900px) {
        .login-card {
            flex-direction: column;
            height: auto;
        }

        .login-left,
        .login-right {
            padding: 50px 30px;
        }

        .login-wrapper {
            transform: none;
            padding: 16px;
        }

        .right-content {
            transform: none;
        }
    }
</style>