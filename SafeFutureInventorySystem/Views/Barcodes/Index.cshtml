@model List<SafeFutureInventorySystem.Models.BarcodeRecord>
@{
    ViewData["Title"] = "Saved Barcodes";
}

<div class="text-center">
    <h1>Saved Barcodes</h1>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Inventory Item Id</th>
            <th>Value</th>
            <th>Format</th>
            <th>Generated At (UTC)</th>
            <th>Image</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var r in Model)
    {
        <tr>
            <td>@r.Id</td>
            <td>@r.InventoryItemId</td>
            <td>@r.Value</td>
            <td>@r.Format</td>
            <td>@r.GeneratedAt.ToString("u")</td>
            <td><a class="btn btn-sm btn-secondary" href="@Url.Action("ImageRecord","Barcodes", new { id = r.Id })" target="_blank">View</a></td>
        </tr>
    }
    </tbody>
</table>
