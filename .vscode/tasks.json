{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build .NET project",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Run ASP.NET Core app",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"SafeFutureInventorySystem"
			],
			"problemMatcher": [
				"$msCompile"
			],
			"group": "test"
		}
	]
}